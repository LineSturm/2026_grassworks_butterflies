"Pred_site_var3_Hill2_target.csv")) %>%
dplyr::mutate(obs.year = as.factor(obs.year),
region = factor(region, levels = c("North", "Centre", "South")))
my_theme <- function() {
theme_test() +
theme(
text = element_text(size = 18, color = "black"),
axis.text = element_text(size = 18, color = "black"),
plot.title = element_text(size = 14,  color = "black", face = "bold"),
plot.subtitle = element_text(size = 18,  color = "black", face = "bold"),
legend.position = "bottom",
legend.title = element_blank(),
legend.text = element_text(margin = ggplot2::margin(l = 2, unit = "mm"), size = 14),
strip.background = element_rect(fill = "white", colour = "black")
)
}
## (A) Target species richness ####
FigS5A <-
ggplot(data, aes(rest.age, butterfly.rich.target, color = region )) +
geom_point() +
my_theme() +
geom_line(data = Pred_site_var3_spe_rich_target, linewidth = 1) +
scale_color_manual(values = c("North" = "#bbc1c6", "Centre" = "#8e98a1", "South" = "#555b60")) +
labs(title = "", subtitle = "(A) Target species richness",
y = "", x = "Age of restored sites")
print(FigS5A)
## (B) Target abundance ####
FigS5B <-
ggplot(data, aes(rest.age, butterfly.target.abu, color = region )) +
geom_point() +
my_theme() +
geom_line(data = Pred_site_var2_abu_target, linewidth = 1) +
scale_color_manual(values = c("North" = "#bbc1c6", "Centre" = "#8e98a1", "South" = "#555b60")) +
labs(title = "", subtitle = "(B) Target abundance",
y = "", x = "Age of restored sites")
print(FigS5B)
## (C) Target Hill-Simpson diversity ####
FigS5C <-
ggplot(data, aes(rest.age, butterfly.Hill2.target, color = region)) +
geom_point() +
facet_wrap(~obs.year) +
scale_color_manual(values = c("North" = "#bbc1c6", "Centre" = "#8e98a1", "South" = "#555b60")) +
my_theme() +
geom_line(data = Pred_site_var3_Hill2_target, linewidth = 1) +
labs(title = "", subtitle = "(C) Target Hill-Simpson diversity",
y = "", x = "Age of restored sites")
print(FigS5C)
## combine ####
